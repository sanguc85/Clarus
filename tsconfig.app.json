    "strictPropertyInitialization": false,
    "outDir": "./out-tsc/app",
    "types": [
      "hammerjs",
      "jasmine",
      "node",
      "@types/file-saver"
    ]
  },
  "files": [
    "src/main.ts",
    "src/polyfills.ts"
  ],
  "include": [
    "src/**/*.d.ts"
  ]
}
